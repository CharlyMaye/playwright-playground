    "eslint": "^10.2.0",
    "eslint-plugin-playwright": "^2.10.1",
    "globals": "^17.5.0",
    "json-rules-engine": "^7.3.1",
    "monocart-reporter": "^2.9.22",
    "prettier": "^3.6.2",
